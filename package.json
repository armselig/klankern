{
    "name": "klankern",
    "version": "0.1.0",
    "description": "A web application for families to manage common family tasks together and collaborate.",
    "type": "module",
    "private": true,
    "scripts": {
        "build": "nuxt build",
        "dev": "nuxt dev",
        "generate": "nuxt generate",
        "preview": "nuxt preview",
        "test": "vitest run",
        "test:ui": "vitest --ui",
        "test:nuxt": "vitest run --project nuxt",
        "postinstall": "nuxt prepare",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "tsx server/db/migrate.ts",
        "db:seed": "tsx server/db/seed.ts",
        "db:start": "podman-compose up -d",
        "db:stop": "podman-compose down",
        "lint": "eslint .",
        "lint:fix": "eslint --fix .",
        "format": "prettier --write ."
    },
    "dependencies": {
        "@pinia/nuxt": "0.11.2",
        "nuxt": "^4.1.2",
        "nuxt-auth-utils": "0.5.25",
        "nuxt-security": "2.4.0",
        "pinia": "3.0.3",
        "vue": "^3.5.22",
        "vue-router": "^4.5.1",
        "winston": "3.17.0",
        "zod": "4.1.11"
    },
    "keywords": [],
    "author": "Hendrik Neumann <henne@armselig.net>",
    "license": "UNLICENSED",
    "engines": {
        "node": "^22.17.0",
        "pnpm": "^10.13.1"
    },
    "packageManager": "pnpm@10.13.1",
    "devDependencies": {
        "@nuxt/eslint": "^1.9.0",
        "@nuxt/eslint-config": "^1.9.0",
        "@nuxt/test-utils": "3.19.2",
        "@types/pg": "8.15.5",
        "@typescript-eslint/eslint-plugin": "8.44.1",
        "@typescript-eslint/parser": "^8.45.0",
        "@vue/test-utils": "2.4.6",
        "dotenv": "17.2.2",
        "drizzle-kit": "^0.31.5",
        "drizzle-orm": "0.44.5",
        "eslint": "^9.36.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-import-resolver-typescript": "4.4.4",
        "eslint-plugin-import": "2.32.0",
        "eslint-plugin-prettier": "^5.5.4",
        "eslint-plugin-vue": "^10.5.0",
        "eslint-plugin-vuejs-accessibility": "2.4.1",
        "happy-dom": "^18.0.1",
        "lefthook": "1.13.4",
        "pg": "8.16.3",
        "prettier": "^3.6.2",
        "prettier-plugin-vue": "^1.1.6",
        "tsx": "4.20.6",
        "typescript": "5.9.2",
        "vitest": "3.2.4",
        "vue-eslint-parser": "10.2.0"
    },
    "browserslist": [
        "defaults, > 0.2% in de"
    ]
}
